{
  "name": "@fernandoslim/odoo-jsonrpc",
  "version": "2.1.0",
  "description": "A lightweight Odoo JSON-RPC client with zero dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "readme.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fernandoslim/odoo-jsonrpc.git"
  },
  "keywords": [
    "odoo",
    "jsonrpc",
    "typescript",
    "rpc",
    "client"
  ],
  "author": "Fernando Slim <xferchox@gmail.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/fernandoslim/odoo-jsonrpc/issues"
  },
  "homepage": "https://github.com/fernandoslim/odoo-jsonrpc#readme",
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
